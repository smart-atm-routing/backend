# ----- Runtime -----
NODE_ENV=development
PORT=3000

# Comma-separated allowed CORS origins (admin dashboard, Gmail add-on)
CORS_ORIGINS=http://localhost:5173

# Secret used to sign cookies (min 16 chars). Generate a strong value per env.
COOKIE_SECRET=replace-with-32-char-random-secret

# ----- PostgreSQL (pgvector) -----
# From the host, Postgres is published on 5433 (compose maps 5433->5432).
# When running the app inside docker-compose, host override uses postgres:5432.
DATABASE_URL=postgresql://salesbox:salesbox@localhost:5433/salesbox?schema=public

# ----- Redis -----
REDIS_HOST=localhost
REDIS_PORT=6379

# ----- Rate limiting (Redis-backed) -----
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# ----- Google OAuth (Gmail) -----
# From Google Cloud Console → Clients (Web application).
GOOGLE_CLIENT_ID=replace-with-google-client-id
GOOGLE_CLIENT_SECRET=replace-with-google-client-secret
# Must match the Console "Authorized redirect URIs" entry EXACTLY.
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/google/callback
# Space-separated scopes. Confirm exact Gmail scopes 
GOOGLE_SCOPES=https://www.googleapis.com/auth/gmail.readonly
