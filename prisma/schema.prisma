// Inbox Sales Copilot — Prisma schema (foundation scaffold).
// Intentionally minimal: no domain models yet (modeled in a later sprint).
// pgvector is enabled now so RAG embedding tables are unblocked later.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

generator erd {
  provider = "prisma-erd-generator"
  output   = "ERD.md"
  // Markdown (Mermaid) output — no Chromium/mmdc needed. Becomes a real
  // diagram once domain models are added in a later sprint.
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// Connected Gmail OAuth accounts. Access/refresh tokens are stored
// encrypted at rest.
model ConnectedAccount {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String    @unique
  accessToken    String    @map("access_token")
  refreshToken   String?   @map("refresh_token")
  scope          String?
  tokenExpiresAt DateTime? @map("token_expires_at") @db.Timestamptz(6)
  status         String    @default("connected")
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("connected_accounts")
}
